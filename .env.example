# Copy to `.env.local` and adjust.
# Restart the Next.js server after changing any NEXT_PUBLIC_* value.

# development | production
NEXT_PUBLIC_APP_ENV=development

NEXT_PUBLIC_DEV_API_URL=http://localhost:8000
NEXT_PUBLIC_DEV_WS_URL=ws://localhost:8000

NEXT_PUBLIC_PROD_API_URL=https://archon-backend-mc2k.onrender.com
NEXT_PUBLIC_PROD_WS_URL=wss://archon-backend-mc2k.onrender.com

NEXT_PUBLIC_APP_NAME=Archon
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=true
